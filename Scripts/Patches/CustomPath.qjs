		prefix : "Recommended QuestInfoList Lua",
		parts : ["system\\RecommendedQuestInfoList", "_Sakray", "_True"],
		recommendedValue : "SystemEN/RecommendedQuests"
	},

	'CustomspopupLub',
	{
		strType : "Path",
		varName : '$newspopup',
		prefix : "spopup Lua",
