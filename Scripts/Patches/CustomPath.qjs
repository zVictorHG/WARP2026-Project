///
/// \brief Common function to change specific file paths
///
CustomPath = function(_)
{
	$$(_, 1.1, `Ensure 'Disable BGM' is not selected (unless in test mode)`);
	if (!Warp.TestMode && _ === 'CustomDefaultBGM')
		Warp.SetPatchState("NoBGMAudio", false);

	$$(_, 1.2, `Retrieve the data for the index`);
	const {varName, prefix, strType, name, nameAddr} = this.Data.get(_);

	$$(_, 1.3, `Find location where the string is PUSHed`);
	let addr = Exe.FindHex(PUSH(nameAddr));
	let refAddrs;
	let dest = ECX;

	if (addr < 0 && ROC.FullVer == 14.29 && _ === 'CustomPrivAirplaneLub')
	{
		const aLoad1 = Exe.FindHex(MOVUPS(XMM0, [nameAddr]));
		if (aLoad1 < 0)
			throw Error("PrivAirplane: MOVUPS XMM0,[name] not found");

		const cmovPush = Exe.FindHex(
			CMOVAE(EAX, [EBP, -0x28]) + PUSH(EAX),
			aLoad1, aLoad1 + 0x120
		);
		if (cmovPush < 0)
			throw Error("PrivAirplane: CMOVAE/PUSH site not found");

		refAddrs = ['PATCH_PRIVAIRPLANE_CMOV2PUSH', cmovPush];
		dest = ECX;
	}

	if (addr < 0 && ROC.FullVer == 14.29 && _ === 'CustomspopupLub')
	{
		let localPtr = [EBP, WCn];
		const parts =
		[
			PUSH(0x20)
		+	MOV(localPtr, 0xF)
		+	MOV(BYTE_PTR, localPtr, 0)
		+	CALL(ALLWC),

			MOVUPS(XMM0, [nameAddr]),

			MOV(localPtr, 0x11)
		+	MOV(localPtr, 0x1F),

			MOVUPS([EAX], XMM0)
		+	MOV(CL, [nameAddr + 0x10])
		+	MOV(BYTE_PTR, [EAX, 0x10], CL)
		+	MOV(BYTE_PTR, [EAX, 0x11], 0)
		];
		dest = EAX;
		addr = Exe.FindHex(parts);
		if (addr > 0)
		{
			const addrs   = MapAddrs(addr, parts);
			const cutFrom = addrs[1];
			const cutTo   = addrs[3] + parts[3].byteCount();
			refAddrs = ['HOOK_SPOPUP_TAIL', cutFrom, cutTo, addrs[2]];
		}
	}

	const isQuestQuali = (_ === 'CustomQuestQualiLub');
	if (addr < 0 && isQuestQuali)
	{
		const nameCandidates = [ "System\\QuestClassificationInfo.lub" ];
		let strAddr = -1;
		for (const s of nameCandidates)
		{
			strAddr = Exe.FindText(s, CASE_INSENSITIVE);
			if (strAddr > 0) break;
			strAddr = Exe.FindText(s.replace("/", "\\"), CASE_INSENSITIVE);
			if (strAddr > 0) break;
		}
		if (strAddr < 0)
			throw Error("'System\\QuestClassificationInfo.lub' not found");

		const aLoad1 = Exe.FindHex(MOVUPS(XMM0, [strAddr]));
		if (aLoad1 < 0)
			throw Error("QuestQuali: MOVUPS XMM0,[str] not found");

		const searchFrom = aLoad1;
		const searchTo   = aLoad1 + 0x80;
		const storePats = [
			MOVUPS([EAX], XMM0),
			MOVDQU ? MOVDQU([EAX], XMM0) : null,
			MOVAPS ? MOVAPS([EAX], XMM0) : null
		].filter(Boolean);

		let aStore1 = -1;
		for (const pat of storePats) {
			const pos = Exe.FindHex(pat, searchFrom, searchTo);
			if (pos > 0) { aStore1 = pos; break; }
		}
		if (aStore1 < 0)
			throw Error("QuestQuali: store [EAX],XMM0 not found");

		let term = MOV(BYTE_PTR, [EAX, 0x22], 0);
		let termAt = Exe.FindHex(term, aStore1, aStore1 + 0x200);
		if (termAt < 0) {
			term = MOV(BYTE_PTR, [EAX, 0x24], 0);
			termAt = Exe.FindHex(term, aStore1, aStore1 + 0x200);
		}
		if (termAt < 0)
			throw Error("QuestQuali: terminator write not found");

		const cutFrom = aStore1;
		const cutTo   = termAt + term.byteCount();

		refAddrs = ['HOOK_QUESTQUALI_TAIL', cutFrom, cutTo];
		dest = EAX;
	}

	/* Rune-system files are loaded via inline MOVUPS+MOVQ+MOV(byte|dword)
	 * copy sequences with hardcoded byte counts and length immediates
	 * (see Ghidra RE notes on CRuneSystemMgr::LoadLuaTables).  No PUSH
	 * reference exists for the 4 MOV-loaded sites, so they need their
	 * own detection path. */
	/* Byte-copy sites (MOV r8, m8 at +0x25) can be extended by up to +3
	 * chars via the byte->dword opcode flip.  Dword-copy sites already
	 * consume 4 bytes there, no room left to extend. */
	const isRuneByteCopy  = (_ === 'CustomitemDecomLub' || _ === 'CustomRuneInfoLub');
	const isRuneDwordCopy = (_ === 'CustomRuneSystemIdLub');
	const isRuneSystem_MOV = isRuneByteCopy || isRuneDwordCopy;
	const isRuneSystemTable = (_ === 'CustomRuneSystemTableLub');
	const isRuneMOVSite = isRuneSystem_MOV || isRuneSystemTable;
	const isRunePush = (_ === 'CustomRuneDescLub'       ||
	                    _ === 'CustomRuneSetDescLub'    ||
	                    _ === 'CustomRuneSetInfoLub'    ||
	                    _ === 'CustomRuneRewardLub'     ||
	                    _ === 'CustomRuneSystemInfoLub');

	{
		const hasSite = (addr >= 0) || !!refAddrs;
		if (!hasSite && !isQuestQuali && !isRuneMOVSite)
			throw Error(`'${name} not used`);
	}

	const suf = strType === "Prefix" ? "without .lub" : "";
	const recVal = this.Data.get(_).recommendedValue;
	const recNote = recVal ? `<br><br><small><i>If you're using llchrisll Translation Project this is Recommended.</i></small><br><br>Recommended value: <b>${recVal}</b><br>` : "";
	/* MOV sites have architectural length limits:
	 *   - byte-copy set (itemDecom / rune_info): extensible up to +3
	 *     by flipping MOV byte -> MOV dword at offset +0x25/+0x2B.
	 *   - runesystemid: already MOV dword; locked at origLen.
	 *   - RuneSystemTable: 2 MOVUPS copying exactly 32 bytes; locked at origLen.
	 * Caps below are upper bounds; per-site validation happens after
	 * we read the current opcode. */
	const runeCap = isRuneByteCopy ? name.length + 3
	              : isRuneDwordCopy ? name.length
	              : isRuneSystemTable ? name.length
	              : isRunePush ? name.length
	              : 64;
	const newStr = Exe.GetUserInput(
		varName, D_Text, `File ${strType}`,
		`Enter the new <b>${prefix} ${strType}</b> (relative to RO folder) ${suf}${recNote}`,
		name, {minLen: 1, maxLen: runeCap}
	);
	if (newStr === false)
		Cancel(strType, name);

	const [, freeVir] = Exe.AddFromVar(varName);

	/* --- Rune MOV-site handling -----------------------------------
	 * Locate the MOVUPS-from-nameAddr site via its 7-byte signature,
	 * then:
	 *   short (newLen < origLen): allocate a fresh origLen+1 buffer,
	 *     copy newStr, null-pad rest, point the 3 MOV source operands
	 *     at it.  C-string terminates at first null, std::string.size
	 *     stays at origLen (benign for file loading).
	 *   equal: patch the 3 source operands only.
	 *   long (newLen > origLen, byte-copy sites only): flip MOV byte
	 *     -> MOV dword (opcodes 0x8A->0x8B and 0x88->0x89, both keep
	 *     encoding size at 6 and 3 bytes respectively), bump length
	 *     immediate at +0x0A and null-terminator offset at +0x30. */
	if (isRuneSystem_MOV)
	{
		const origLen = name.length;
		const newLen  = newStr.length;

		const movupsBytes = [0x0F, 0x10, 0x05,
			 nameAddr         & 0xFF,
			(nameAddr >>  8)  & 0xFF,
			(nameAddr >> 16)  & 0xFF,
			(nameAddr >> 24)  & 0xFF];
		const movupsHex = movupsBytes.map(b => b.toString(16).padStart(2, '0')).join(' ');
		const aMovups   = Exe.FindHex(movupsHex);
		if (aMovups < 0)
			throw Error(`${_}: MOVUPS load site for ${name} not found`);

		let srcVir = freeVir;

		if (newLen < origLen)
		{
			const [padPhy, padVir] = Exe.Allocate(origLen + 1, 0x10);
			for (let i = 0; i < newLen; i++)
				Exe.SetUint8(padPhy + i, newStr.charCodeAt(i));
			for (let i = newLen; i <= origLen; i++)
				Exe.SetUint8(padPhy + i, 0);
			srcVir = padVir;
		}
		else if (newLen > origLen)
		{
			const curOpc = Exe.GetUint8(aMovups + 0x25);
			if (curOpc === 0x8A)
			{
				if (newLen > origLen + 3)
					throw Error(`${_}: replacement too long (${newLen}); max ${origLen + 3} at this site`);
				Exe.SetUint8(aMovups + 0x25, 0x8B); // MOV r8, m8  -> MOV r32, m32
				Exe.SetUint8(aMovups + 0x2B, 0x89); // MOV m8, r8  -> MOV m32, r32
				Exe.SetUint8(aMovups + 0x0A, newLen);   // length immediate
				Exe.SetUint8(aMovups + 0x30, newLen);   // null-terminator offset
			}
			else if (curOpc === 0x8B)
			{
				throw Error(`${_}: copy chain already dword-wide; cannot extend past ${origLen} chars`);
			}
			else
			{
				throw Error(`${_}: unexpected opcode 0x${curOpc.toString(16)} at MOVUPS+0x25`);
			}
		}

		Exe.SetUint32(aMovups + 0x03, srcVir);
		Exe.SetUint32(aMovups + 0x1C, srcVir + 0x10);
		Exe.SetUint32(aMovups + 0x27, srcVir + 0x18);

		if (addr > 0)
			Exe.SetUint32(addr + 1, srcVir);
	}
	else if (isRuneSystemTable)
	{
		const origLen = name.length; // 32 for System\Rune\runeSystem_table.lub
		const newLen  = newStr.length;

		const movupsBytes = [0x0F, 0x10, 0x05,
			 nameAddr         & 0xFF,
			(nameAddr >>  8)  & 0xFF,
			(nameAddr >> 16)  & 0xFF,
			(nameAddr >> 24)  & 0xFF];
		const movupsHex = movupsBytes.map(b => b.toString(16).padStart(2, '0')).join(' ');
		const aMovups   = Exe.FindHex(movupsHex);
		if (aMovups < 0)
			throw Error(`${_}: MOVUPS load site for ${name} not found`);

		let srcVir = freeVir;

		if (newLen < origLen)
		{
			const [padPhy, padVir] = Exe.Allocate(origLen + 1, 0x10);
			for (let i = 0; i < newLen; i++)
				Exe.SetUint8(padPhy + i, newStr.charCodeAt(i));
			for (let i = newLen; i <= origLen; i++)
				Exe.SetUint8(padPhy + i, 0);
			srcVir = padVir;
		}
		// newLen > origLen blocked by runeCap; newLen == origLen uses freeVir directly.

		Exe.SetUint32(aMovups + 0x03, srcVir);
		Exe.SetUint32(aMovups + 0x1B, srcVir + 0x10);

		if (addr > 0)
			Exe.SetUint32(addr + 1, srcVir);
	}
	else if (refAddrs == undefined)
	{
		Exe.SetUint32(addr + 1, freeVir);
	}

	else if (Array.isArray(refAddrs) && refAddrs[0] === 'PATCH_PRIVAIRPLANE_CMOV2PUSH')
	{
		const cmovPush = refAddrs[1];
		Exe.SetInt8 (cmovPush + 0, 0x68);
		Exe.SetUint32(cmovPush + 1, freeVir);
	}

	else if (Array.isArray(refAddrs) && refAddrs[0] === 'HOOK_QUESTQUALI_TAIL')
	{
		const cutFrom = refAddrs[1];
		const cutTo   = refAddrs[2];

		let dsize = newStr.length, offset = 0, code = '';
		[
			[0x10, MOVUPS, XMM0, EAX],
			[0x08, MOVQ,   EDX,  EAX],
			[0x04, MOV,    EDX,  EAX],
			[0x01, MOV,    DL,   EAX]
		].forEach(([fsize, cmd, reg, dst]) =>
		{
			let nextOff = offset + fsize;
			while (nextOff <= dsize) {
				code += cmd(reg, [freeVir + offset])
				     + cmd([dst, offset], reg);
				offset = nextOff;
				nextOff += fsize;
			}
		});

		code += MOV(BYTE_PTR, [EAX, offset], 0)
		      + JMP(Filler(1));

		Exe.SetNOPs(cutFrom, cutTo - cutFrom);
		AutoHook(cutFrom, code, { targets: { 1: Exe.Phy2Vir(cutTo, CODE) } });
	}

	else if (Array.isArray(refAddrs) && refAddrs[0] === 'HOOK_SPOPUP_TAIL')
	{
		const cutFrom  = refAddrs[1];
		const cutTo    = refAddrs[2];
		const midAddr  = refAddrs[3];

		// detect disp8 vs disp32 and read EBP offsets from original MOV instructions
		const isDisp8_1 = (Exe.GetUint8(midAddr + 1) === 0x45);
		const ebpOff1   = isDisp8_1 ? Exe.GetInt8(midAddr + 2) : Exe.GetInt32(midAddr + 2);
		const mov2Start = midAddr + (isDisp8_1 ? 7 : 10);
		const isDisp8_2 = (Exe.GetUint8(mov2Start + 1) === 0x45);
		const ebpOff2   = isDisp8_2 ? Exe.GetInt8(mov2Start + 2) : Exe.GetInt32(mov2Start + 2);

		let dsize = newStr.length, offset = 0, code = '';
		[
			[0x10, MOVUPS, XMM0, EAX],
			[0x08, MOVQ,   EDX,  EAX],
			[0x04, MOV,    EDX,  EAX],
			[0x01, MOV,    DL,   EAX]
		].forEach(([fsize, cmd, reg, dst]) =>
		{
			let nextOff = offset + fsize;
			while (nextOff <= dsize) {
				code += cmd(reg, [freeVir + offset])
				     + cmd([dst, offset], reg);
				offset = nextOff;
				nextOff += fsize;
			}
		});

		code += MOV(BYTE_PTR, [EAX, offset], 0)
		      + MOV([EBP, ebpOff1], newStr.length)
		      + MOV([EBP, ebpOff2], newStr.length | 0xF)
		      + JMP(Filler(1));

		Exe.SetNOPs(cutFrom, cutTo - cutFrom);
		AutoHook(cutFrom, code, { targets: { 1: Exe.Phy2Vir(cutTo, CODE) } });
	}

	return true;
};

///
/// \brief Common functions to validate
///
CustomPath.validate = function(_)
{
	let data = this.Data.get(_);

	if ('parts' in data) //need to derive the name from parts and then find its address.
	{
		const [pref, sakSufs, mainSufs] = data.parts;
		const sufs = Wrap(ROC.IsRenewal ? sakSufs : mainSufs);

		const result = sufs.findAs( suf =>
		{
			let name = pref + suf;
			let addr = Exe.FindText(name, CASE_INSENSITIVE);

			if (addr < 0 && Exe.BuildDate > 20211000)
			{
				name = pref.replace("/", "\\") + suf;
				addr = Exe.FindText(name, CASE_INSENSITIVE);
			}

			if (addr > 0)
				return [name, addr];
			else
				return null;
		});
		if (result)
		{
			[data.name, data.nameAddr] = result;
			return true;
		}
	}
	else //name is provided directly
	{
		let name = data.knownName;
		let addr = Exe.FindText(name, CASE_INSENSITIVE);

		if (addr < 0 && Exe.BuildDate > 20211000)
		{
			name = name.replace("/", "\\");
			addr = Exe.FindText(name, CASE_INSENSITIVE);
		}
		if (addr > 0)
		{
			data.nameAddr = addr;
			data.name = name;
			return true;
		}
	}

	return false;
};

///
/// Wrappers for Individual Patches
///
CustomDefaultBGM       = CustomPath;
CustomItemInfoLub      = CustomPath;
CustomAchieveLub       = CustomPath;
CustomTownInfoLub      = CustomPath;
CustomPetEvoClnLub     = CustomPath;
CustomTipboxLub        = CustomPath;
CustomCheckAttLub      = CustomPath;
CustomPrivAirplaneLub  = CustomPath;
CustomMapInfoLub       = CustomPath;
CustomOngQuestInfoLub  = CustomPath;
CustomRcmdQuestInfoLub = CustomPath;
CustomMonSizeEffLub    = CustomPath;
CustomspopupLub        = CustomPath;
CustomChangeMatLub     = CustomPath;
CustomQuestQualiLub    = CustomPath;
CustomRuneDescLub      = CustomPath;
CustomRuneSetDescLub   = CustomPath;
CustomitemDecomLub     = CustomPath;
CustomRuneInfoLub      = CustomPath;
CustomRuneSetInfoLub   = CustomPath;
CustomRuneSystemTableLub = CustomPath;
CustomRuneSystemIdLub  = CustomPath;
CustomRuneSystemInfoLub = CustomPath;
CustomRuneRewardLub = CustomPath;

///
/// \brief Data to be used for the above patches
///
CustomPath.Data = MakeMap(
	'CustomDefaultBGM',
	{
		strType : "Path",
		varName : '$newBGMPath',
		prefix : "Default BGM",
		knownName : "bgm\\01.mp3"
	},

	'CustomItemInfoLub',
	{
		strType : "Path",
		varName : '$newItemInfo',
		prefix : "ItemInfo Lua",
		parts : ["System/iteminfo", ["_Sak.lub", ".lub"], ["_true.lub", ".lub"]],
		recommendedValue : "SystemEN/iteminfo.lua"
	},

	'CustomAchieveLub',
	{
		strType : "Path",
		varName : '$newAchieveList',
		prefix : "Achievement List Lua",
		knownName : "system\\Achievement_list.lub",
		recommendedValue : "SystemEN/achievements.lub"
	},

	'CustomMonSizeEffLub',
	{
		strType : "Path",
		varName : '$newMonSizeEffect',
		prefix : "Monster Size Effect Lua",
		parts : ["System/monster_size_effect", ["_sak_new.lub", "_sak.lub", ".lub"], ["_new.lub", ".lub"]],
		recommendedValue : "SystemEN/monster_size_effect.lub"
	},

	'CustomTownInfoLub',
	{
		strType : "Path",
		varName : '$newTownInfo',
		prefix : "Town Info Lua",
		knownName : "System/Towninfo.lub",
		recommendedValue : "SystemEN/Towninfo.lub"
	},

	'CustomPetEvoClnLub',
	{
		strType : "Path",
		varName : '$newPetEvoCln',
		prefix : "Pet Evolution Lua",
		parts : ["system\\PetEvolutionCln", ["_sak.lub", ".lub"], ["_true.lub", ".lub"]],
		recommendedValue : "SystemEN/PetEvolution.lub"
	},

	'CustomTipboxLub',
	{
		strType : "Path",
		varName : '$newTipBox',
		prefix : "Tip Box Lua",
		knownName : "System/tipbox.lub",
		recommendedValue : "SystemEN/tipbox.lub"
	},

	'CustomCheckAttLub',
	{
		strType : "Path",
		varName : '$newCheckAtt',
		prefix : "Check Attendance Lua",
		knownName : "System/CheckAttendance.lub",
		recommendedValue : "SystemEN/CheckAttendance.lub"
	},

	'CustomPrivAirplaneLub',
